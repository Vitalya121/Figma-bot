{
  "name": "@carousel-forge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@carousel-forge/types": "workspace:*",
    "@carousel-forge/config": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0",
    "bullmq": "^5.30.0",
    "ioredis": "^5.4.0",
    "zod": "^3.24.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.30.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0"
  }
}
